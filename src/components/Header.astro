---
import Link from '@components/HeaderLink.astro';

const navLinks = [
	{name: 'Home', url: '/'},
	{name: 'Contact Us', url: 'https://www.paypal.com/seller/form/Oj0ffao9mD'},
];
---

<header>
	<div id="logo-banner">
		<img src="favicon.svg" />
		<h1>Wolfsrudel LLC</h1>
	</div>
	<nav>
		{navLinks.map(link => <Link url={link.url} name={link.name} />)}
	</nav>
</header>

<style lang="scss">
@use '@assets/styles' as theme;
$banner-height: 48px;

header {
	padding: 0 12px;
	display: flex;
	justify-content: space-between;
	align-items: center;
	background-color: theme.get-color('background');
	#logo-banner {
		display: flex;
		align-items: center;
		padding: 4px;
		&> * {
			margin: 0 4px;
		}
		img {
			width: $banner-height;
			height: $banner-height;
		}
		h1 {
			display: none;
			font-size: theme.$base-font-size;
		}
	}
	nav {
		color: theme.get-color('default');
		display: flex;
		font: 1em sans-serif;
		padding: 0 8px;
		justify-content: center;
		align-items: stretch;
	}
	@media only screen and (min-width: theme.$breakpoint-desktop) {
		#logo-banner h1 {
			display: inline-block;
		}
	}
}
</style>
